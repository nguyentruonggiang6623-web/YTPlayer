{
  "name": "ytplayer",
  "version": "1.0.0",
  "description": "YTPlayer Offline App",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend && electron-builder"
  },
  "build": {
    "appId": "com.ytplayer.app",
    "productName": "YTPlayer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.2.0",
    "nodemon": "^3.1.14",
    "youtube-dl-exec": "^3.1.9"
  }
}
